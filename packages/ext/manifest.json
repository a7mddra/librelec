{
  "manifest_version": 3,
  "name": "Libre-Lec Bridge",
  "version": "0.1.0",
  "description": "Bridge .edu pages with a local libre-lec process.",
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["*://*.sml4.dmu.edu.eg/*", "ws://localhost/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:*;"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sml4.dmu.edu.eg/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["*://*.sml4.dmu.edu.eg/*"]
    }
  ]
}
