{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["packages/tui/src/*"]
    },
    "lib": ["ES2022"],
    "types": ["node", "react"]
  },
  "include": ["tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": ["packages"]
}
